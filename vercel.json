{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/privacy",    "destination": "/public/privacy.html" },
    { "source": "/terms",      "destination": "/public/terms.html" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
